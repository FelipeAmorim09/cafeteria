# Copie este arquivo para .env e preencha os valores.
# O .env real é ignorado pelo git (.gitignore) — nunca suba segredos.

# Chave de assinatura das sessões. Gere uma com:
#   py -c "import secrets; print(secrets.token_hex(32))"
# (se deixar vazio, a aplicação gera uma automaticamente no primeiro run)
SECRET_KEY=

# 1 = modo debug do Flask (apenas em desenvolvimento!)
FLASK_DEBUG=0

# 1 = cookies de sessão só via HTTPS (ative em produção)
SESSION_COOKIE_SECURE=0
